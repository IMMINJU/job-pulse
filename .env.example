# Database
DATABASE_URL=                  # Neon PostgreSQL connection string

# Job source APIs
ADZUNA_APP_ID=                 # https://developer.adzuna.com
ADZUNA_APP_KEY=
RAPIDAPI_KEY=                  # https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch

# LLM (HN parsing + weekly insight generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini      # (optional) default model for insight + HN parsing (1M context fits full HN thread)
OPENAI_INPUT_USD_PER_MTOK=     # (optional) USD per 1M input tokens (default 0.20)
OPENAI_OUTPUT_USD_PER_MTOK=    # (optional) USD per 1M output tokens (default 0.80)

# Report delivery
GOOGLE_CHAT_WEBHOOK_URL=       # primary webhook for weekly report
FAILURE_WEBHOOK_URL=           # (optional) separate channel for pipeline failures

# Pipeline
PIPELINE_SECRET=               # shared secret for manual /api/pipeline/run trigger
